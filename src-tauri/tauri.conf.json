{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipShot",
  "version": "0.1.0",
  "identifier": "com.heung.clip-shot",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "클립샷",
        "width": 940,
        "height": 660,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "backgroundColor": "#f4f4f3",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "화면 캡처 → 클립보드 + 최근 30개 히스토리",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
